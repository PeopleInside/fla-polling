{
    "name": "peopleinside/fla-polling",
    "description": "Lightweight real-time polling for Flarum 2.0 - No WebSocket, No SSH required",
    "type": "flarum-extension",
    "license": "MIT",
    "homepage": "https://github.com/PeopleInside/fla-polling",
    "authors": [
        {
            "name": "PeopleInside",
            "homepage": "https://github.com/PeopleInside"
        }
    ],
    "require": {
        "flarum/core": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PeopleInside\\FlaPolling\\": "src/"
        }
    },
    "support": {
        "source": "https://github.com/PeopleInside/fla-polling",
        "issues": "https://github.com/PeopleInside/fla-polling/issues"
    },
    "extra": {
        "flarum-extension": {
            "title": "FLA Polling",
            "category": "feature",
            "icon": {
                "name": "fas fa-sync-alt",
                "backgroundColor": "#4a90e2",
                "color": "#fff"
            }
        }
    }
}
